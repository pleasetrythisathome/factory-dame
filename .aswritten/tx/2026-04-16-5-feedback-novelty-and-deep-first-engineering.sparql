# ── Sample ───────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260416T230000Z {
    narr:Sample_NoveltyDeepFirst_20260416 a narr:Sample ;
      dct:title "Feedback: novelty is the whole point, and build deep-first not shallow-first" ;
      dct:created "2026-04-16"^^xsd:date ;
      dct:description "Project-strategy-level feedback from Scarlet during the voice-extraction architecture discussion (2026-04-16). Two interlocking claims: (1) factory-dame exists to do something genuinely novel that couldn't exist before AI-enabled complex-systems development; (2) build each component to publishable/novel depth before moving to the next, rather than sweeping shallowly across all components first." ;
      narr:inputLength 5241 .
  }
} ;

# ── New Narratives ───────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260416T230000Z {

    narr:Narrative_NoveltyAsNorthStar a narr:Narrative ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:broader narr:PositioningThesis ;
      skos:note "Scarlet's explicit north-star criterion for factory-dame: the project has no goal unless it does something truly novel and incredible that couldn't exist before AI-enabled complex-systems development. 'Pragmatic' is not a north star. Every architectural decision must be checked against whether it leverages NRT's distinctive properties or merely replicates what DAW plugins and eurorack modules already do. Shipping a competent NRT-powered beat tracker is a failure mode; shipping per-voice dynamic phase-coherent motor networks that generate polyrhythmic CV for arbitrary live audio is the goal." ;
      narr:theme "Novelty as the only valid north star for factory-dame: if it replicates existing DSP capabilities, there is no reason to have built it" .

    narr:Narrative_DeepFirstNotShallowFirst a narr:Narrative ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:broader narr:FocusSequencing ;
      skos:note "A direct correction to the default engineering pattern of phased shallow-then-deep development. Each component must be built to publishable/novel depth before moving to the next. The failure mode of shallow-first: the shallow system ships, works well enough, pressure to go deep evaporates, and the novel capability never materializes. The alternative: each phase is a standalone novel capability you could ship. This is slower per-phase but arrives at genuinely novel ground. The horizontal shallow sweep never does." ;
      narr:theme "Build each component to publishable depth first, then assemble — never sweep shallowly across all components and plan to deepen later" .
  }
} ;

# ── New Claims ───────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260416T230000Z {

    narr:Claim_NoveltyNorthStar a narr:Claim ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:note "Scarlet's verbatim: 'I have no goal with this project unless it does something truly novel and incredible.' Factory-dame exists specifically to do something that couldn't exist before AI-enabled complex-systems development unlocked it." ;
      narr:aboutNode narr:Narrative_NoveltyAsNorthStar ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_NoveltyAsNorthStar .

    narr:Claim_PragmaticNotNorthStar a narr:Claim ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:note "'Pragmatic' is explicitly not a north star for factory-dame. The operative question is: 'Does this produce a capability that genuinely didn't exist before?' When choosing between a proven-but-boring approach and a harder-but-novel approach, default to the novel one — even if it's more work, even if the first version is rough." ;
      narr:aboutNode narr:Narrative_NoveltyAsNorthStar ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_NoveltyAsNorthStar .

    narr:Claim_DefaultToNovelArchitecturalChoice a narr:Claim ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:note "Every architectural decision should be checked: is this choice leveraging NRT's distinctive properties, or is this a choice that could have been made in a conventional DSP pipeline? Default to the more-ambitious architectural choice over the pragmatic one, unless there is a specific reason (time, budget, external constraint) the ambitious one is unworkable in the session. The NRT analysis-is-synthesis property (Narrative_AnalysisIsSynthesis) is the specific well of novelty." ;
      narr:aboutNode narr:Narrative_NoveltyAsNorthStar ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_AnalysisIsSynthesis .

    narr:Claim_CompetentBeatTrackerFailureMode a narr:Claim ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:note "Shipping a 'competent NRT-powered beat tracker' is a failure mode. Conventional beat trackers, chromagrams, and filter banks already exist. If the project ends up replicating what DAW plugins and eurorack modules already do, there is no reason to have built it. The goal is 'per-voice dynamic phase-coherent motor networks that generate polyrhythmic CV for arbitrary live audio'." ;
      narr:aboutNode narr:Narrative_NoveltyAsNorthStar ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:challenges narr:Narrative_NRTAsDynamicalSystemsAlternative .

    narr:Claim_DeepFirstPhaseModel a narr:Claim ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:note "The correct phasing model: P1 = component A built to publishable/novel depth (not an MVP, the real thing); P2 = component B built the same way; P3 = component C same. Each phase is a standalone novel capability you could ship. This is slower per-phase but arrives at genuinely novel ground." ;
      narr:aboutNode narr:Narrative_DeepFirstNotShallowFirst ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_DeepFirstNotShallowFirst .

    narr:Claim_ShallowFirstFailureMode a narr:Claim ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:note "The failure mode of shallow-first phasing: ship the shallow system, it works, the pressure to go deep evaporates because the shallow version is 'fine,' and the novel capability never materializes. You end up with a competent implementation of a conventional approach. The horizontal shallow sweep never arrives at genuinely novel ground." ;
      narr:aboutNode narr:Narrative_DeepFirstNotShallowFirst ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_DeepFirstNotShallowFirst .

    narr:Claim_VolumeOverPerfectionScopeLimit a narr:Claim ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:note "Volume-over-perfection still applies to content and artifacts (from earlier feedback) — but NOT to core technical capabilities. Content goes wide; capabilities go deep. This scopes the earlier volume-over-perfection principle and prevents it from being misapplied to architectural decisions." ;
      narr:aboutNode narr:Narrative_DeepFirstNotShallowFirst ;
      narr:hasConvictionLevel narr:Conviction_Foundation .

    narr:Claim_NoveltyConstraintOnCounterweight a narr:Claim ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:note "The creative counterweight role now includes the constraint that factory-dame must be novel, not merely creative. A competent replica of existing tech doesn't satisfy the counterweight role — the project exists to do something that couldn't exist before, not just to be a creative outlet." ;
      narr:aboutNode narr:Narrative_CreativeCounterweightToAswritten ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_CreativeCounterweightToAswritten .

    narr:Claim_Task011DeepFirstPlan a narr:Claim ;
      dct:source narr:Sample_NoveltyDeepFirst_20260416 ;
      skos:note "task-011 (CV/MIDI/OSC router) deep-first plan: Phase 1 = voice identity done to publishable depth (phase-coherence clustering, voice tracking across frames, tested on multiple real tracks, visually legible — not 'simple threshold clustering we'll improve later'); Phase 2 = per-voice rhythm association to the same depth; Phase 3 = per-voice motor coupling (reading existing motor state as multi-voice; or per-voice motor network pool if reading proves insufficient). Each phase is a standalone novel capability you could ship." ;
      narr:aboutNode narr:Narrative_DeepFirstNotShallowFirst ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_LiveNRTModularBridge .
  }
} ;

