# ── Updates to existing entities ─────────────────────────────────
# UPDATE 1: Narrative_LiveNRTModularBridge — reframe from 'ship something functional'
# to 'ship something that couldn't exist before'
DELETE {
  GRAPH ?g {
    narr:Narrative_LiveNRTModularBridge skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260416T230000Z {
    narr:Narrative_LiveNRTModularBridge skos:note "A product-level unification of the existing factory-dame backlog into a single coherent use case: hardware or software that listens to live audio and outputs CV, MIDI, and OSC for all perceptual parameters — tempo, tonic, key, dynamics — so a modular synthesizer can improvise live alongside arbitrary audio (jazz open mic, DJ sets, streamed tracks, field recordings). Architecturally founded on Narrative_AnalysisIsSynthesis: the same oscillator state driving generative art IS the CV signal. No direct competitor in the 'listen to arbitrary audio, output continuous musical CV' space. Reframed per 2026-04-16 feedback: the goal is not to ship something functional but to ship something that couldn't exist before — a capability genuinely unlocked by AI-enabled complex-systems development. Shipping a competent NRT-powered beat tracker would be a failure mode." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_LiveNRTModularBridge skos:note ?oldNote .
  }
} ;

# UPDATE 2: Narrative_CreativeCounterweightToAswritten — add novelty constraint
DELETE {
  GRAPH ?g {
    narr:Narrative_CreativeCounterweightToAswritten skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260416T230000Z {
    narr:Narrative_CreativeCounterweightToAswritten skos:note "Aswritten demands speed and pragmatism ('dumber and faster'). The generative 3D project provides breathing room and a space for purely creative work unconstrained by business velocity. Updated per 2026-04-16 feedback: the counterweight role now includes the constraint that factory-dame must be novel, not merely creative. A competent replica of existing tech (DAW plugins, eurorack modules) does not satisfy the counterweight role — the project exists to do something that couldn't exist before AI-enabled complex-systems development." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_CreativeCounterweightToAswritten skos:note ?oldNote .
  }
} ;

# UPDATE 3: Claim_Task011CVMIDIOSCRouter — add deep-first phased plan
DELETE {
  GRAPH ?g {
    narr:Claim_Task011CVMIDIOSCRouter skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260416T230000Z {
    narr:Claim_Task011CVMIDIOSCRouter skos:note "task-011 (CV/MIDI/OSC output router) is the new backlog ticket created during this session, with task-004 and task-005 as dependencies. It subscribes to the live perceptual state stream and maps extractor outputs to CV channels, MIDI messages, and OSC. task-010 (OSC schema documentation) becomes load-bearing as the consumer contract. Per 2026-04-16 deep-first feedback, task-011 is to be built deep-first: Phase 1 = voice identity to publishable depth (phase-coherence clustering, voice tracking across frames, tested on multiple real tracks, visually legible — not 'simple threshold clustering we'll improve later'); Phase 2 = per-voice rhythm association to the same depth; Phase 3 = per-voice motor coupling (reading existing motor state as multi-voice; or per-voice motor network pool if reading proves insufficient). Each phase is a standalone novel capability you could ship." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_Task011CVMIDIOSCRouter skos:note ?oldNote .
  }
}