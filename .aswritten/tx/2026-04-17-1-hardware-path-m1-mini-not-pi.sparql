INSERT DATA {
  GRAPH narr:Tx_20260416T235959Z {
    narr:Sample_HardwarePathM1Mini_20260416 a narr:Sample ;
      dct:title "Hardware path for the live-NRT-to-modular vision: M1 Mac mini, not Raspberry Pi" ;
      dct:created "2026-04-16"^^xsd:date ;
      narr:inputLength 1850 .

    narr:Claim_M1MiniMidTermPath a narr:Claim ;
      narr:aboutNode narr:Narrative_LiveNRTModularBridge ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_HardwarePathM1Mini_20260416 ;
      skos:note "The mid-term hardware path is the M1 Mac mini 8GB (already owned), running headless via SSH. This replaces the previous Raspberry Pi 5 / LattePanda suggestion." .

    narr:Claim_PiShelved a narr:Claim ;
      narr:aboutNode narr:Narrative_LiveNRTModularBridge ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_HardwarePathM1Mini_20260416 ;
      skos:note "Raspberry Pi or custom SBC deployment is shelved unless external demand for a low-cost form factor materializes." .

    narr:Claim_OptimizationForLiveMode a narr:Claim ;
      narr:aboutNode narr:Narrative_LiveNRTModularBridge ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_HardwarePathM1Mini_20260416 ;
      skos:note "Engine optimization (task-015) is required to enable live mode (task-005), not for hardware compatibility. The engine needs a 3x speedup even on M-series hardware to stream audio chunks at 1x realtime." .

    narr:Claim_NoveltyOverHardwareEngineering a narr:Claim ;
      narr:aboutNode narr:Narrative_NoveltyAsNorthStar ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_DeepFirstNotShallowFirst ;
      dct:source narr:Sample_HardwarePathM1Mini_20260416 ;
      skos:note "When hardware-compatibility optimization competes with novel-capability investment, choose the latter. The novelty lives in the engine and voice primitives, not the deployment hardware." .

    narr:StyleMetrics_HardwarePathM1Mini a narr:StyleMetrics ;
      skos:broader narr:StyleMetrics ;
      dct:source narr:Sample_HardwarePathM1Mini_20260416 ;
      narr:AverageSentenceLength 16 ;
      narr:ActiveVoiceRatio 0.85 ;
      narr:JargonDensity 0.12 ;
      skos:note "Direct, corrective register. Uses structured lists and explicit 'Correction' headers. High conviction." .

    narr:StyleObs_CorrectionMarker a narr:StyleObservation ;
