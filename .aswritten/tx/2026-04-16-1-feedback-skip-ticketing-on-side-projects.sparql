    narr:Sample_SkipTicketing_20260416 a narr:Sample ;
      dct:title "Feedback: Skip ticketing / process overhead on factory-dame" ;
      dct:description "Scarlet's explicit preference to skip persistent backlog/ticketing for the factory-dame neurodynamics engine project, with behavioral rules for how to handle task management going forward." ;
      dct:created "2026-04-16"^^xsd:date ;
      narr:inputLength 1847 .

    # ── New Narrative: Process minimalism for creative projects ──────────────
    narr:Narrative_ProcessMinimalismCreativeProjects a narr:Narrative ;
      dct:source narr:Sample_SkipTicketing_20260416 ;
      skos:broader narr:OrganizationalChangeManual ;
      narr:theme "Process minimalism as a deliberate feature of creative side projects" ;
      skos:note "Scarlet explicitly rejects persistent ticketing, GitHub issues, and backlog artifacts for factory-dame. In-session task lists (TaskCreate) are acceptable as working-memory tools. Session boundaries are handled via conversation summaries, not tickets. This is scoped to the creative project only — aswritten and business projects retain structured task management." .

    # ── Claims: Section 1 — The preference ──────────────────────────────────
    narr:Claim_ScarletAntiTicketingPreference a narr:Claim ;
      dct:source narr:Sample_SkipTicketing_20260416 ;
      narr:aboutNode narr:Narrative_ProcessMinimalismCreativeProjects ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_CreativeCounterweightToAswritten ;
      skos:note "Scarlet explicitly declined an offer to create ~18 tickets in Backlog.md covering viz polish, Tier 2–4 features, and live audio. She asked to just proceed without persistent task management artifacts." .

    # ── Claims: Section 3 — How to apply going forward ───────────────────────
    narr:Claim_InSessionTaskCreateOK a narr:Claim ;
      dct:source narr:Sample_SkipTicketing_20260416 ;
      narr:aboutNode narr:Narrative_ProcessMinimalismCreativeProjects ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      skos:note "In-session TaskCreate is still welcome when actively juggling multiple features during a build — it is a working-memory tool, not a planning artifact. The objection is specifically to persistent tickets for future work." .

    narr:Claim_SessionBoundarySummaryNotTickets a narr:Claim ;
      dct:source narr:Sample_SkipTicketing_20260416 ;
      narr:aboutNode narr:Narrative_ProcessMinimalismCreativeProjects ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      skos:note "At session boundaries, summarize in conversation ('what's done / what's next') rather than creating tickets. Thread continuity across sessions goes into an aswritten memory, not a backlog." .

    narr:Claim_AntiTicketingScopeCreativeOnly a narr:Claim ;
      dct:source narr:Sample_SkipTicketing_20260416 ;
      narr:aboutNode narr:Narrative_ProcessMinimalismCreativeProjects ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      skos:note "The anti-ticketing preference does NOT apply to aswritten or business projects — structured task management remains appropriate there. This is specifically scoped to the factory-dame creative side project." .

    # ── Observations ─────────────────────────────────────────────────────────
    narr:Obs_ScarletAntiBacklogQuote a narr:Observation ;
      skos:broader narr:FeedbackLoops ;
      dct:source narr:Sample_SkipTicketing_20260416 ;
      skos:note "Scarlet's verbatim pushback on backlog creation — casual, decisive, action-oriented register" ;
      oa:hasSelector [
