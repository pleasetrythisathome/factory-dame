INSERT {
  GRAPH narr:Tx_20260416T120000Z {
    narr:Narrative_AIWorkflowSandbox skos:note "Scarlet deliberately uses this project to push Claude Code practice, test multi-agent systems, and try coordinators (Martin's factory-factory, Conductor) without risking aswritten's velocity. The sandbox dimension explicitly includes discovering which collaboration rituals are welcome vs. unwelcome — e.g., in-session TaskCreate is fine; persistent backlog tickets are not. The project surfaces what AI-human creative collaboration actually needs vs. what business process imposes." .
  }
}
WHERE {
