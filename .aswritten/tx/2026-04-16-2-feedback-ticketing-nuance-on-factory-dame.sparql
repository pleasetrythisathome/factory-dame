      narr:aboutNode narr:Narrative_ProcessMinimalismCreativeProjects ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_ProcessMinimalismCreativeProjects .

    narr:Claim_StructureEarnsItsKeep
      a narr:Claim ;
      dct:source narr:Sample_LightStructureCorrection_20260416 ;
      skos:note "The test for whether to create structure on factory-dame is 'does this carry weight later?' — not 'is this Backlog.md?'. Handoff docs, tickets for work actually on-deck, and decision docs for non-trivial calls all pass the test. Reflexive ticketing of every idea does not." ;
      narr:aboutNode narr:Narrative_ProcessMinimalismCreativeProjects ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_ProcessMinimalismCreativeProjects .

    narr:Claim_NoTicketInflation
      a narr:Claim ;
      dct:source narr:Sample_LightStructureCorrection_20260416 ;
      skos:note "Don't propose creating 18 tickets for every idea downstream. Propose one ticket when it's warranted. The spirit the earlier memory got right: velocity tracking and reflexive ticketing of every future idea would import the wrong energy into a creative counterweight project." ;
      narr:aboutNode narr:Narrative_ProcessMinimalismCreativeProjects ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_CreativeCounterweightToAswritten .
