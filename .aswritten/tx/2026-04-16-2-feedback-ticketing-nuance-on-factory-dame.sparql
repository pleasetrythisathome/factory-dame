}
INSERT {
  GRAPH narr:Tx_20260416T180000Z {
    narr:Claim_ScarletAntiTicketingPreference
      narr:hasConvictionLevel narr:Conviction_Stake ;
      skos:note "Scarlet declines reflexive or high-volume ticketing for factory-dame — not any ticketing. She explicitly corrected the earlier memory ('that memory about not doing backlog was way overplayed'), endorsed the handoff doc and 10 backlog tickets from the prior session, and chose to keep them rather than rebase them out. The objection is to ticket inflation and process-driven workflows, not to structure that earns its keep." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ScarletAntiTicketingPreference
      narr:hasConvictionLevel ?oldLevel ;
      skos:note ?oldNote .
  }
} ;

