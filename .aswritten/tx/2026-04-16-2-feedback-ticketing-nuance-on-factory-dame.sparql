# ── UPDATE: Narrative_ProcessMinimalismCreativeProjects ──────────────────────
# Memory reframes from "explicitly rejects" to "light touch, not zero touch".
DELETE {
  GRAPH ?g {
    narr:Narrative_ProcessMinimalismCreativeProjects
      skos:note ?oldNote ;
      narr:theme ?oldTheme .
  }
}
INSERT {
  GRAPH narr:Tx_20260416T180000Z {
    narr:Narrative_ProcessMinimalismCreativeProjects
      skos:note "Scarlet's preference for factory-dame is light touch, not zero touch. She declines reflexive ticketing, velocity tracking, and process-driven workflows that import the wrong energy into a creative project. But structure is welcome when it earns its keep: handoff docs between sessions, tickets for work actually on-deck, decision docs for non-trivial calls. The earlier 'Do NOT propose creating Backlog.md tickets' directive is superseded. In-session TaskCreate remains acceptable as a working-memory tool. Scoped to factory-dame only — aswritten and business projects retain structured task management." ;
      narr:theme "Light-touch process minimalism as deliberate feature of creative side projects — structure welcome when it earns its keep" .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ProcessMinimalismCreativeProjects
      skos:note ?oldNote ;
      narr:theme ?oldTheme .
  }
} ;

